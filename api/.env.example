APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_ALLOW_ORIGINS=*

MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/ooop_admin?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_AUTO_MIGRATE=false

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_TTL=720h
JWT_ISSUER=ooop-admin-api

AUTH_CODE_SECRET=replace-with-code-secret

JIGUANG_APP_KEY=
JIGUANG_MASTER_SECRET=
JIGUANG_PUSH_URL=https://api.jpush.cn/v3/push

ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_MOBILE_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
ALIYUN_ID_CARD_ENDPOINT=https://kzidcardv1.market.alicloudapi.com/api-mall/api/id_card/check
ALIYUN_ID_CARD_APP_CODE=
ALIYUN_ID_CARD_APP_KEY=
ALIYUN_ID_CARD_APP_SECRET=

# 内容安全文本审核；启用后第三方异常会阻止内容入库
ALIYUN_CONTENT_MODERATION_ENABLED=false
ALIYUN_CONTENT_MODERATION_ENDPOINT=green-cip.cn-shanghai.aliyuncs.com
ALIYUN_CONTENT_MODERATION_NICKNAME_SERVICE=nickname_detection
ALIYUN_CONTENT_MODERATION_CONTENT_SERVICE=pgc_detection
# 本地禁用词使用英文逗号分隔，优先于第三方审核
CONTENT_MODERATION_BLOCKED_WORDS=

# 项目内相对路径（文件放 api/secrets/，已 gitignore）
HARMONY_PUSH_SERVICE_ACCOUNT_FILE=secrets/harmony-push-service-account.json
HARMONY_PUSH_URL=https://push-api.cloud.huawei.com
# 调测 true；生产 false
HARMONY_PUSH_TEST_MESSAGE=false

QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=ooop
QINIU_DOMAIN=https://source.ooopai.cn
