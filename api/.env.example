APP_ENV=development
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
HTTP_ALLOW_ORIGINS=*

MYSQL_DSN=root:root@tcp(127.0.0.1:3306)/ooop_admin?charset=utf8mb4&parseTime=True&loc=Local
MYSQL_AUTO_MIGRATE=false

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TOKEN_TTL=720h
JWT_ISSUER=ooop-admin-api

AUTH_CODE_SECRET=replace-with-code-secret

ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_MOBILE_ENDPOINT=dypnsapi.aliyuncs.com
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=

QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=ooop
QINIU_DOMAIN=https://source.ooopai.cn
